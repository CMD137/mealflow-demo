# MealFlow local environment template. Copy to .env and fill real values locally.
# Do not commit .env or real cloud credentials.

# local | aliyun-oss
MEALFLOW_STORAGE_PROVIDER=local
MEALFLOW_STORAGE_PUBLIC_BASE_URL=

# Required only when MEALFLOW_STORAGE_PROVIDER=aliyun-oss.
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_OBJECT_PREFIX=catalog
